 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "# Smart Insect Identifier — Model Training (Colab)\n**Nama:** KhairunNisa  \n**NPM:** 2308107010074  \n**Dataset:** Kaggle Insects Dataset (118 Classes)  \n**Model:** EfficientNetB0 (ImageNet Pretrained)  \n**Image Size:** 224×224  \n**Platform:** Google Colab GPU  \n**Training Strategy:** Transfer Learning + Fine-Tuning + IMPROVED AUGMENTATION"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 0. Persiapan Dataset"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "!pip install -q kaggle tensorflow matplotlib seaborn scikit-learn\n\nimport os\nfrom google.colab import userdata\n\nos.environ['KAGGLE_USERNAME'] = userdata.get('KAGGLE_USERNAME')\nos.environ['KAGGLE_KEY']      = userdata.get('KAGGLE_KEY')\n\nDATASET_PATH = '/content/insects'\nos.makedirs(DATASET_PATH, exist_ok=True)\n\n!kaggle datasets download -d baxtiyorbotiraliyev/insects -p {DATASET_PATH} --unzip -q\n\nprint(\"✅ Dataset berhasil diunduh ke:\", DATASET_PATH)\nprint(\"📁 Isi folder:\")\nfor item in sorted(os.listdir(DATASET_PATH))[:10]:\n    print(\" \", item)"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 1. Import Library & Konfigurasi"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "import os, json, random, time, warnings\nimport numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nwarnings.filterwarnings('ignore')\n\nimport tensorflow as tf\nfrom tensorflow import keras\nfrom tensorflow.keras import layers\nfrom tensorflow.keras.applications import EfficientNetB0\nfrom tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau, ModelCheckpoint\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.metrics import (\n    classification_report, confusion_matrix,\n    precision_score, recall_score, f1_score, accuracy_score\n)\nfrom sklearn.utils import class_weight\nfrom pathlib import Path\nfrom PIL import Image\n\nSEED = 42\nrandom.seed(SEED)\nnp.random.seed(SEED)\ntf.random.set_seed(SEED)\n\nfrom tensorflow.keras import mixed_precision\nmixed_precision.set_global_policy('mixed_float16')\n\nIMG_SIZE    = (224, 224)\nBATCH_SIZE  = 32\nEPOCHS_TL   = 50\nEPOCHS_FT   = 60\n\nMODEL_TL_PATH = '/content/model_efficientnet_TL.keras'\nMODEL_FT_PATH = '/content/model_efficientnet_FT.keras'\nMETADATA_PATH = '/content/model_metadata.json'\n\nprint(f\"TensorFlow : {tf.__version__}\")\nprint(f\"GPU        : {tf.config.list_physical_devices('GPU')}\")\nprint(f\"Policy     : {mixed_precision.global_policy()}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## 2. Konfigurasi Path & Verifikasi Dataset"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "from pathlib import Path\n\nIMAGE_ROOT = Path(DATASET_PATH)\n\nclass_dirs = sorted([d for d in IMAGE_ROOT.iterdir() if d.is_dir()])\n\nif len(class_dirs) == 1:\n    IMAGE_ROOT = class_dirs[0]\n    class_dirs = sorted([d for d in IMAGE_ROOT.iterdir() if d.is_dir()])\n\nCLASS_NAMES = [d.name for d in class_dirs]\nNUM_CLASSES = len(CLASS_NAMES)\n\nprint(f\"📂 IMAGE_ROOT  : {IMAGE_ROOT}\")\nprint(f\"🐛 Jumlah kelas: {NUM_CLASSES}\")\nprint(f\"📋 Contoh kelas: {CLASS_NAMES[:5]}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## A. Data Preprocessing"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "CACHE_PATH = '/content/sampled_cache.json'\n\nif os.path.exists(CACHE_PATH):\n    print(\"⚡ Cache ditemukan — skip scan dataset, load dari cache...\")\n    with open(CACHE_PATH) as f:\n        cache = json.load(f)\n    all_paths  = np.array(cache['paths'])\n    all_labels = np.array(cache['labels'])\n    CLASS_NAMES = cache['class_names']\n    NUM_CLASSES = len(CLASS_NAMES)\n    print(f\"✅ Loaded {len(all_paths):,} gambar dari cache\")\nelse:\n    print(\"🔍 Scan dataset pertama kali (hanya sekali)...\")\n    all_ds_raw = tf.keras.utils.image_dataset_from_directory(\n        str(IMAGE_ROOT),\n        seed        = SEED,\n        image_size  = IMG_SIZE,\n        batch_size  = None,\n        label_mode  = 'int',\n        shuffle     = True\n    )\n    CLASS_NAMES = all_ds_raw.class_names\n    NUM_CLASSES = len(CLASS_NAMES)\n\n    all_paths, all_labels = [], []\n    for path, label in all_ds_raw.take(-1):\n        all_paths.append(path.numpy().decode())\n        all_labels.append(label.numpy())\n\n    all_paths  = np.array(all_paths)\n    all_labels = np.array(all_labels)\n\n    with open(CACHE_PATH, 'w') as f:\n        json.dump({\n            'paths'       : all_paths.tolist(),\n            'labels'      : all_labels.tolist(),\n            'class_names' : CLASS_NAMES\n        }, f)\n    print(f\"✅ Cache disimpan ke {CACHE_PATH}\")\n\nprint(f\"Kelas ditemukan: {NUM_CLASSES}\")\nprint(f\"Total gambar   : {len(all_paths):,}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Sampling — Maksimal 500 gambar per kelas"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "from collections import defaultdict\n\nMAX_PER_CLASS = 500\n\ngrouped = defaultdict(list)\nfor p, l in zip(all_paths, all_labels):\n    grouped[l].append((p, l))\n\nsampled_paths, sampled_labels = [], []\nfor lbl, items in grouped.items():\n    if len(items) > MAX_PER_CLASS:\n        items = random.sample(items, MAX_PER_CLASS)\n    for p, l in items:\n        sampled_paths.append(p)\n        sampled_labels.append(l)\n\nsampled_paths  = np.array(sampled_paths)\nsampled_labels = np.array(sampled_labels)\nprint(f\"Gambar setelah sampling: {len(sampled_paths):,}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Train / Validation / Test Split"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "X_trainval, X_test, y_trainval, y_test = train_test_split(\n    sampled_paths, sampled_labels,\n    test_size=0.10, stratify=sampled_labels, random_state=SEED\n)\nX_train, X_val, y_train, y_val = train_test_split(\n    X_trainval, y_trainval,\n    test_size=0.15/(1-0.10), stratify=y_trainval, random_state=SEED\n)\n\nprint(f\"Train : {len(X_train):,}\")\nprint(f\"Val   : {len(X_val):,}\")\nprint(f\"Test  : {len(X_test):,}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Distribusi Dataset per Kelas"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "IMG_EXTENSIONS = {'.jpg','.jpeg','.png','.bmp','.webp'}\n\nclass_counts = {}\nfor cls_dir in class_dirs:\n    imgs = [f for f in cls_dir.rglob('*') if f.suffix.lower() in IMG_EXTENSIONS]\n    class_counts[cls_dir.name] = len(imgs)\n\ntotal_imgs = sum(class_counts.values())\nprint(f\"\\n📊 Total gambar    : {total_imgs:,}\")\nprint(f\"Rata-rata/kelas   : {total_imgs // NUM_CLASSES:,}\")\nprint(f\"Min               : {min(class_counts.values()):,}  |  Max: {max(class_counts.values()):,}\")\n\nfig, ax = plt.subplots(figsize=(max(10, NUM_CLASSES * 0.55), 5))\ncolors  = plt.cm.viridis(np.linspace(0, 1, NUM_CLASSES))\nsc      = dict(sorted(class_counts.items()))\nbars    = ax.bar(list(sc.keys()), list(sc.values()), color=colors)\nax.set_xlabel('Kelas Serangga', fontsize=12)\nax.set_ylabel('Jumlah Gambar',  fontsize=12)\nax.set_title('Distribusi Dataset per Kelas', fontsize=14, fontweight='bold')\nplt.xticks(rotation=45, ha='right', fontsize=8)\nfor bar, val in zip(bars, sc.values()):\n    ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+5,\n            str(val), ha='center', va='bottom', fontsize=7)\nplt.tight_layout()\nplt.savefig('/content/class_distribution.png', dpi=120, bbox_inches='tight')\nplt.show()\n\nprint(\"\\nDistribusi per kelas:\")\nfor k, v in sorted(class_counts.items()):\n    print(f\"  {k:<30}: {v:>5} gambar\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Sampel Gambar per Kelas"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "n_show = min(NUM_CLASSES, 12)\ncols   = 6\nrows   = (n_show + cols - 1) // cols\nfig, axes = plt.subplots(rows, cols, figsize=(cols*2.5, rows*2.5))\naxes = axes.flatten()\n\nshow_classes = random.sample(CLASS_NAMES, n_show)\nfor i, cls_name in enumerate(show_classes):\n    cls_path = IMAGE_ROOT / cls_name\n    imgs = [f for f in cls_path.rglob('*') if f.suffix.lower() in IMG_EXTENSIONS]\n    if imgs:\n        img = Image.open(random.choice(imgs)).convert('RGB')\n        axes[i].imshow(img)\n        axes[i].set_title(cls_name, fontsize=8, fontweight='bold')\n    axes[i].axis('off')\nfor j in range(n_show, len(axes)):\n    axes[j].set_visible(False)\nplt.suptitle('Sampel Gambar per Kelas', fontsize=13, fontweight='bold')\nplt.tight_layout()\nplt.savefig('/content/sample_images.png', dpi=120, bbox_inches='tight')\nplt.show()"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### AGGRESSIVE Augmentasi & TF Data Pipeline"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "data_augmentation = tf.keras.Sequential([\n    layers.RandomFlip('horizontal'),\n    layers.RandomFlip('vertical'),\n    layers.RandomRotation(0.20),\n    layers.RandomZoom(0.20),\n    layers.RandomBrightness(0.2),\n    layers.RandomContrast(0.2),\n    layers.RandomTranslation(0.1, 0.1),\n], name='augmentation')\n\nAUTOTUNE = tf.data.AUTOTUNE\n\ndef make_ds(paths, labels, aug=False, shuffle=False):\n    ds = tf.data.Dataset.from_tensor_slices((paths, labels))\n    if shuffle:\n        ds = ds.shuffle(len(paths), seed=SEED)\n\n    def load(path, label):\n        raw = tf.io.read_file(path)\n        img = tf.image.decode_jpeg(raw, channels=3, try_recover_truncated=True)\n        img = tf.image.resize(img, IMG_SIZE)\n        img = tf.cast(img, tf.float32) / 255.0\n        if aug:\n            img = data_augmentation(img, training=True)\n        img = tf.clip_by_value(img, 0.0, 1.0)\n        return img, label\n\n    ds = (ds\n          .map(load, num_parallel_calls=AUTOTUNE)\n          .ignore_errors()\n          .batch(BATCH_SIZE)\n          .prefetch(AUTOTUNE))\n    return ds\n\ntrain_ds = make_ds(X_train, y_train, aug=True,  shuffle=True)\nval_ds   = make_ds(X_val,   y_val)\ntest_ds  = make_ds(X_test,  y_test)\n\nprint(\"✅ Pipeline siap\")\nprint(f\"   train batches : {len(train_ds)}\")\nprint(f\"   val   batches : {len(val_ds)}\")\nprint(f\"   test  batches : {len(test_ds)}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Class Weights"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "cw = class_weight.compute_class_weight(\n    class_weight='balanced',\n    classes=np.arange(NUM_CLASSES),\n    y=y_train\n)\nclass_weights = dict(enumerate(cw))\nprint(f\"Class weights — min: {min(class_weights.values()):.3f}  max: {max(class_weights.values()):.3f}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## B. Implementasi Transfer Learning"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "def build_tl_model(num_classes):\n    base_model = EfficientNetB0(\n        weights='imagenet', include_top=False,\n        input_shape=IMG_SIZE+(3,)\n    )\n    base_model.trainable = False\n\n    inputs  = keras.Input(shape=IMG_SIZE+(3,))\n    x       = base_model(inputs, training=False)\n    x       = layers.GlobalAveragePooling2D()(x)\n    x       = layers.BatchNormalization()(x)\n    x       = layers.Dense(512, activation='relu')(x)\n    x       = layers.Dropout(0.40)(x)\n    x       = layers.Dense(256, activation='relu')(x)\n    x       = layers.Dropout(0.30)(x)\n    x       = layers.Dense(128, activation='relu')(x)\n    x       = layers.Dropout(0.20)(x)\n    outputs = layers.Dense(num_classes, activation='softmax', dtype='float32')(x)\n\n    model = keras.Model(inputs, outputs, name='EfficientNetB0_TL')\n    return model, base_model\n\nmodel_tl, base_model = build_tl_model(NUM_CLASSES)\nmodel_tl.summary()"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Kompilasi & Callbacks — Transfer Learning"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "model_tl.compile(\n    optimizer=keras.optimizers.Adam(5e-4),\n    loss='sparse_categorical_crossentropy',\n    metrics=['accuracy']\n)\n\ncallbacks_tl = [\n    EarlyStopping(monitor='val_accuracy', patience=8,\n                  restore_best_weights=True, verbose=1),\n    ReduceLROnPlateau(monitor='val_loss', factor=0.5,\n                      patience=4, min_lr=1e-7, verbose=1),\n    ModelCheckpoint(MODEL_TL_PATH, monitor='val_accuracy',\n                    save_best_only=True, mode='max', verbose=1),\n]\n\ntrainable = sum(np.prod(v.shape) for v in model_tl.trainable_variables)\nprint(f\"Trainable params : {trainable:,}\")\nprint(f\"Max epochs       : {EPOCHS_TL}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## D. Training\n\n### Training Phase 1 — Transfer Learning (Frozen Base)"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "HISTORY_TL_PATH = '/content/history_tl.json'\n\ndef get_last_epoch(history_path):\n    if os.path.exists(history_path):\n        with open(history_path) as f:\n            h = json.load(f)\n        return len(h['accuracy']), h\n    return 0, None\n\nlast_epoch_tl, saved_hist_tl = get_last_epoch(HISTORY_TL_PATH)\n\nif last_epoch_tl >= EPOCHS_TL:\n    print(f\"✅ Training TL sudah selesai ({last_epoch_tl} epoch) — load model TL...\")\n    from tensorflow.keras.models import load_model as _lm\n    model_tl = _lm(MODEL_TL_PATH)\n    history_tl = type('H', (), {'history': saved_hist_tl})()\n    time_tl = 0\nelse:\n    if last_epoch_tl > 0:\n        print(f\"⚡ Resume TL dari epoch {last_epoch_tl} → {EPOCHS_TL}...\")\n        from tensorflow.keras.models import load_model as _lm\n        model_tl = _lm(MODEL_TL_PATH)\n        model_tl.layers[1].trainable = False\n        model_tl.compile(\n            optimizer=keras.optimizers.Adam(5e-4),\n            loss='sparse_categorical_crossentropy',\n            metrics=['accuracy']\n        )\n    else:\n        print(\"🚀 Mulai training Transfer Learning dari awal...\")\n\n    start_tl = time.time()\n    new_hist = model_tl.fit(\n        train_ds,\n        validation_data = val_ds,\n        epochs          = EPOCHS_TL,\n        initial_epoch   = last_epoch_tl,\n        callbacks       = callbacks_tl,\n        class_weight    = class_weights,\n        verbose         = 1\n    )\n    time_tl = time.time() - start_tl\n\n    merged_hist_tl = {}\n    for k in new_hist.history:\n        merged_hist_tl[k] = (saved_hist_tl[k] if saved_hist_tl else []) + new_hist.history[k]\n    history_tl = type('H', (), {'history': merged_hist_tl})()\n\n    with open(HISTORY_TL_PATH, 'w') as f:\n        json.dump(merged_hist_tl, f)\n\n    print(f\"\\n✅ Selesai | Waktu: {time_tl/60:.1f} menit\")\n    print(f\"Best val_accuracy : {max(merged_hist_tl['val_accuracy']):.4f}\")\n    print(f\"Model TL tersimpan di: {MODEL_TL_PATH}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## C. Fine-Tuning"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "base_model.trainable = True\ntotal_layers = len(base_model.layers)\nfine_tune_at = total_layers - 40\n\nfor layer in base_model.layers[:fine_tune_at]:\n    layer.trainable = False\n\nfrozen   = sum(1 for l in base_model.layers if not l.trainable)\nunfrozen = sum(1 for l in base_model.layers if l.trainable)\nprint(f\"Total layer base  : {total_layers}\")\nprint(f\"Layer dibekukan   : {frozen}\")\nprint(f\"Layer dibuka      : {unfrozen}\")\n\nmodel_tl.compile(\n    optimizer=keras.optimizers.Adam(1e-5),\n    loss='sparse_categorical_crossentropy',\n    metrics=['accuracy']\n)\n\ncallbacks_ft = [\n    EarlyStopping(monitor='val_accuracy', patience=8,\n                  restore_best_weights=True, verbose=1),\n    ReduceLROnPlateau(monitor='val_loss', factor=0.5,\n                      patience=4, min_lr=1e-8, verbose=1),\n    ModelCheckpoint(MODEL_FT_PATH, monitor='val_accuracy',\n                    save_best_only=True, mode='max', verbose=1),\n]\n\ntrainable_ft = sum(np.prod(v.shape) for v in model_tl.trainable_variables)\nprint(f\"Trainable params  : {trainable_ft:,}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Training Phase 2 — Fine-Tuning"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "HISTORY_FT_PATH = '/content/history_ft.json'\n\nlast_epoch_ft, saved_hist_ft = get_last_epoch(HISTORY_FT_PATH)\n\nif last_epoch_ft >= EPOCHS_FT:\n    print(f\"✅ Training FT sudah selesai ({last_epoch_ft} epoch) — load model FT...\")\n    from tensorflow.keras.models import load_model as _lm\n    model_ft_final = _lm(MODEL_FT_PATH)\n    history_ft = type('H', (), {'history': saved_hist_ft})()\n    time_ft = 0\nelse:\n    if last_epoch_ft > 0:\n        print(f\"⚡ Resume FT dari epoch {last_epoch_ft} → {EPOCHS_FT}...\")\n        from tensorflow.keras.models import load_model as _lm\n        model_ft_final = _lm(MODEL_FT_PATH)\n        base = model_ft_final.layers[1]\n        base.trainable = True\n        for layer in base.layers[:len(base.layers) - 40]:\n            layer.trainable = False\n        model_ft_final.compile(\n            optimizer=keras.optimizers.Adam(1e-5),\n            loss='sparse_categorical_crossentropy',\n            metrics=['accuracy']\n        )\n    else:\n        print(\"🚀 Mulai training Fine-Tuning dari awal...\")\n        model_ft_final = model_tl\n\n    start_ft = time.time()\n    new_hist_ft = model_ft_final.fit(\n        train_ds,\n        validation_data = val_ds,\n        epochs          = EPOCHS_FT,\n        initial_epoch   = last_epoch_ft,\n        callbacks       = callbacks_ft,\n        class_weight    = class_weights,\n        verbose         = 1\n    )\n    time_ft = time.time() - start_ft\n\n    merged_hist_ft = {}\n    for k in new_hist_ft.history:\n        merged_hist_ft[k] = (saved_hist_ft[k] if saved_hist_ft else []) + new_hist_ft.history[k]\n    history_ft = type('H', (), {'history': merged_hist_ft})()\n\n    with open(HISTORY_FT_PATH, 'w') as f:\n        json.dump(merged_hist_ft, f)\n\n    print(f\"\\n✅ Selesai | Waktu: {time_ft/60:.1f} menit\")\n    print(f\"Best val_accuracy : {max(merged_hist_ft['val_accuracy']):.4f}\")\n    print(f\"Model FT tersimpan di: {MODEL_FT_PATH}\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Kurva Training & Validasi"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n\nep_tl = range(1, len(history_tl.history['accuracy'])+1)\nep_ft = range(1, len(history_ft.history['accuracy'])+1)\n\nfor row, (hist, ep, title_prefix) in enumerate([\n    (history_tl, ep_tl, 'Transfer Learning'),\n    (history_ft, ep_ft, 'Fine-Tuning')\n]):\n    axes[row,0].plot(ep, hist.history['accuracy'],     'b-o', ms=4, lw=2, label='Training')\n    axes[row,0].plot(ep, hist.history['val_accuracy'], 'r-o', ms=4, lw=2, label='Validasi')\n    axes[row,0].set_title(f'{title_prefix} — Accuracy', fontweight='bold')\n    axes[row,0].set_xlabel('Epoch'); axes[row,0].set_ylabel('Accuracy')\n    axes[row,0].set_ylim(0, 1.05); axes[row,0].legend(); axes[row,0].grid(True, ls='--', alpha=0.4)\n    \n    axes[row,1].plot(ep, hist.history['loss'],     'b-o', ms=4, lw=2, label='Training')\n    axes[row,1].plot(ep, hist.history['val_loss'], 'r-o', ms=4, lw=2, label='Validasi')\n    axes[row,1].set_title(f'{title_prefix} — Loss', fontweight='bold')\n    axes[row,1].set_xlabel('Epoch'); axes[row,1].set_ylabel('Loss')\n    axes[row,1].legend(); axes[row,1].grid(True, ls='--', alpha=0.4)\n\nplt.suptitle('Kurva Training & Validasi', fontsize=13, fontweight='bold')\nplt.tight_layout()\nplt.savefig('/content/training_curves.png', dpi=120, bbox_inches='tight')\nplt.show()"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## E. Evaluasi Model"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "from tensorflow.keras.models import load_model\n\nmodel_tl_eval = load_model(MODEL_TL_PATH)\nmodel_ft_eval = load_model(MODEL_FT_PATH)\n\ny_true, y_pred_tl, y_pred_ft = [], [], []\nfor images, labels in test_ds:\n    y_true.extend(labels.numpy())\n    y_pred_tl.extend(np.argmax(model_tl_eval.predict(images, verbose=0), axis=1))\n    y_pred_ft.extend(np.argmax(model_ft_eval.predict(images, verbose=0), axis=1))\n\ny_true    = np.array(y_true)\ny_pred_tl = np.array(y_pred_tl)\ny_pred_ft = np.array(y_pred_ft)"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Metrik Evaluasi"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "def print_metrics(y_true, y_pred, title):\n    acc  = accuracy_score(y_true, y_pred)\n    prec = precision_score(y_true, y_pred, average='weighted', zero_division=0)\n    rec  = recall_score(y_true,  y_pred, average='weighted', zero_division=0)\n    f1   = f1_score(y_true,  y_pred, average='weighted', zero_division=0)\n    print(f\"\\n{'='*50}\")\n    print(f\"  {title}\")\n    print(f\"{'='*50}\")\n    print(f\"  Accuracy  : {acc:.4f}  ({acc*100:.2f}%)\")\n    print(f\"  Precision : {prec:.4f}\")\n    print(f\"  Recall    : {rec:.4f}\")\n    print(f\"  F1-Score  : {f1:.4f}\")\n    print(f\"{'='*50}\")\n    return acc, prec, rec, f1\n\ntl_acc, tl_prec, tl_rec, tl_f1 = print_metrics(y_true, y_pred_tl, \"Transfer Learning — Test Set\")\nft_acc, ft_prec, ft_rec, ft_f1 = print_metrics(y_true, y_pred_ft, \"Fine-Tuning — Test Set\")\n\nprint(f\"\\n🎯 Test Accuracy Transfer Learning : {tl_acc*100:.2f}%\")\nprint(f\"🎯 Test Accuracy Fine-Tuning        : {ft_acc*100:.2f}%\")"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Classification Report"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "from sklearn.metrics import classification_report\nimport matplotlib\nimport matplotlib.pyplot as plt\n\nprint(\"--- Classification Report — Transfer Learning ---\")\nreport_tl = classification_report(y_true, y_pred_tl, target_names=CLASS_NAMES, digits=4, output_dict=False)\nprint(report_tl)\n\nprint(\"\\n--- Classification Report — Fine-Tuning ---\")\nreport_ft = classification_report(y_true, y_pred_ft, target_names=CLASS_NAMES, digits=4, output_dict=False)\nprint(report_ft)\n\ndef save_report_as_image(report_str, title, save_path):\n    lines = report_str.strip().split('\\n')\n    fig_h = max(6, len(lines) * 0.28)\n    fig, ax = plt.subplots(figsize=(14, fig_h))\n    ax.axis('off')\n    ax.text(0.01, 0.99, title, transform=ax.transAxes,\n            fontsize=13, fontweight='bold', va='top', family='monospace')\n    ax.text(0.01, 0.93, report_str, transform=ax.transAxes,\n            fontsize=8.5, va='top', family='monospace',\n            bbox=dict(boxstyle='round', facecolor='#f5f5f5', alpha=0.8))\n    plt.tight_layout()\n    plt.savefig(save_path, dpi=130, bbox_inches='tight')\n    plt.show()\n    print(f\"✅ Disimpan: {save_path}\")\n\nsave_report_as_image(report_tl,\n    'Classification Report — Transfer Learning (Test Set)',\n    '/content/classification_report_TL.png')\n\nsave_report_as_image(report_ft,\n    'Classification Report — Fine-Tuning (Test Set)',\n    '/content/classification_report_FT.png')"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Confusion Matrix"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "fig, axes = plt.subplots(1, 2, figsize=(28, 12))\n\nfor ax, y_p, title in zip(axes,\n    [y_pred_tl, y_pred_ft],\n    ['Confusion Matrix — Transfer Learning', 'Confusion Matrix — Fine-Tuning']):\n    cm   = confusion_matrix(y_true, y_p)\n    cm_n = cm.astype('float') / cm.sum(axis=1)[:, np.newaxis]\n    sns.heatmap(cm_n, annot=False, fmt='.2f', cmap='Blues',\n                xticklabels=CLASS_NAMES, yticklabels=CLASS_NAMES,\n                linewidths=0.3, ax=ax)\n    ax.set_title(title, fontsize=12, fontweight='bold')\n    ax.set_xlabel('Prediksi', fontsize=10)\n    ax.set_ylabel('Label Sebenarnya', fontsize=10)\n    ax.tick_params(axis='x', rotation=45, labelsize=6)\n    ax.tick_params(axis='y', labelsize=6)\n\nplt.tight_layout()\nplt.savefig('/content/confusion_matrix.png', dpi=120, bbox_inches='tight')\nplt.show()"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "### Perbandingan Transfer Learning vs Fine-Tuning"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "metrics_names = ['Accuracy', 'Precision', 'Recall', 'F1-Score']\ntl_vals = [tl_acc, tl_prec, tl_rec, tl_f1]\nft_vals = [ft_acc, ft_prec, ft_rec, ft_f1]\n\nx     = np.arange(len(metrics_names))\nwidth = 0.30\n\nfig, ax = plt.subplots(figsize=(10, 6))\nb1 = ax.bar(x - width/2, tl_vals, width, label='Transfer Learning', color='#4C72B0', alpha=0.85)\nb2 = ax.bar(x + width/2, ft_vals, width, label='Fine-Tuning',       color='#55A868', alpha=0.85)\n\nax.bar_label(b1, fmt='%.4f', padding=3, fontsize=9)\nax.bar_label(b2, fmt='%.4f', padding=3, fontsize=9)\nax.set_xlabel('Metrik')\nax.set_ylabel('Score')\nax.set_title('Perbandingan Transfer Learning vs Fine-Tuning', fontsize=13, fontweight='bold')\nax.set_xticks(x); ax.set_xticklabels(metrics_names)\nax.set_ylim(0, 1.20)\nax.legend(); ax.grid(axis='y', ls='--', alpha=0.4)\nplt.tight_layout()\nplt.savefig('/content/comparison_chart.png', dpi=120, bbox_inches='tight')\nplt.show()\n\nprint(\"\\n\" + \"=\"*55)\nprint(f\"  {'Metrik':<15} {'Transfer Learning':>18} {'Fine-Tuning':>13}\")\nprint(\"-\"*55)\nfor name, tl_v, ft_v in zip(metrics_names, tl_vals, ft_vals):\n    print(f\"  {name:<15} {tl_v:>18.4f} {ft_v:>13.4f}\")\nprint(f\"  {'Waktu (menit)':<15} {time_tl/60:>18.1f} {time_ft/60:>13.1f}\")\nprint(\"=\"*55)"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": "## F. Export Model & Metadata"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": "model_tl_eval.save(MODEL_TL_PATH)\nmodel_tl_eval.save('/content/model_efficientnet_TL.h5')\n\nmodel_ft_eval.save(MODEL_FT_PATH)\nmodel_ft_eval.save('/content/model_efficientnet_FT.h5')\n\nlabel2idx = {c: i for i, c in enumerate(CLASS_NAMES)}\nmetadata  = {\n    'class_names' : CLASS_NAMES,\n    'label2idx'   : label2idx,\n    'num_classes' : NUM_CLASSES,\n    'img_size'    : list(IMG_SIZE),\n    'model'       : 'EfficientNetB0',\n    'test_accuracy_tl' : float(tl_acc),\n    'test_accuracy_ft' : float(ft_acc),\n    'imagenet_mean': [0.485, 0.456, 0.406],\n    'imagenet_std': [0.229, 0.224, 0.225]\n}\nwith open(METADATA_PATH, 'w') as f:\n    json.dump(metadata, f, indent=2)\n\nprint(\"✅ Model TL  (.keras) :\", MODEL_TL_PATH)\nprint(\"✅ Model TL  (.h5)    : /content/model_efficientnet_TL.h5\")\nprint(\"✅ Model FT  (.keras) :\", MODEL_FT_PATH)\nprint(\"✅ Model FT  (.h5)    : /content/model_efficientnet_FT.h5\")\nprint(\"✅ Metadata           :\", METADATA_PATH)\n\nprint(\"\\n📁 Semua output file:\")\noutput_files = [\n    MODEL_TL_PATH, '/content/model_efficientnet_TL.h5',\n    MODEL_FT_PATH, '/content/model_efficientnet_FT.h5',\n    METADATA_PATH,\n    '/content/class_distribution.png', '/content/sample_images.png',\n    '/content/training_curves.png',    '/content/confusion_matrix.png',\n    '/content/comparison_chart.png',   '/content/classification_report_TL.png', '/content/classification_report_FT.png',\n]\nfor fp in output_files:\n    if os.path.exists(fp):\n        size = os.path.getsize(fp)/1e6\n        print(f\"  ✅ {os.path.basename(fp):<45} {size:>7.2f} MB\")\n    else:\n        print(f\"  ❌ {os.path.basename(fp)} — belum ada\")"
  },
